{
  "name": "frontend",
  "kind": "long-running",
  "cwd": "/ABSOLUTE/PATH/TO/PROJECT",
  "launcher": {
    "type": "direct",
    "executable": "/ABSOLUTE/PATH/TO/EXECUTABLE",
    "args": [
      "dev",
      "--host",
      "127.0.0.1"
    ],
    "pathArgs": []
  },
  "environment": {
    "inherit": [
      "PATH"
    ],
    "set": {
      "BROWSER": "none"
    },
    "fromEnv": []
  },
  "stop": {
    "graceSeconds": 8
  },
  "readiness": {
    "type": "http",
    "url": "http://127.0.0.1:5173/health",
    "timeoutSeconds": 30
  },
  "logs": {
    "maxBytes": 10485760,
    "backups": 3
  }
}
