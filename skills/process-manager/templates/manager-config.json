{
  "workspaceRoot": "/ABSOLUTE/PATH/TO/WORKSPACE",
  "stateRoot": "/ABSOLUTE/PATH/TO/WORKSPACE/.harness/process-manager",
  "control": {
    "host": "127.0.0.1",
    "port": 0,
    "maxRequestBytes": 65536
  },
  "history": {
    "maxInactive": 20,
    "maxAgeSeconds": 604800,
    "maxTombstones": 200,
    "deleteRunDirs": true
  },
  "limits": {
    "maxActiveRuns": 16,
    "maxOpenSessions": 32,
    "maxSessionRecords": 128,
    "maxPendingPrunes": 32,
    "maxConcurrentControlRequests": 16,
    "maxRetainedBytes": 536870912
  },
  "logs": {
    "maxBytes": 10485760,
    "backups": 3
  }
}
