{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Evaluation Lab Suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["suite_id", "skill_path", "baseline", "runner", "budgets", "gates", "cases"],
  "properties": {
    "suite_id": {"$ref": "#/$defs/id"},
    "skill_path": {"$ref": "#/$defs/nonEmptyString"},
    "baseline": {
      "oneOf": [
        {"$ref": "#/$defs/noBaseline"},
        {"$ref": "#/$defs/snapshotBaseline"}
      ]
    },
    "runner": {"$ref": "#/$defs/runner"},
    "budgets": {"$ref": "#/$defs/budgets"},
    "gates": {"$ref": "#/$defs/gates"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/triggerCase"},
          {"$ref": "#/$defs/behaviorCase"}
        ]
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:[\\\\/])(?![\\\\/])(?!\\.\\.(?:[\\\\/]|$))(?!.*[\\\\/]\\.\\.(?:[\\\\/]|$)).+$"
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "noBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {"const": "none"}
      }
    },
    "snapshotBaseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "path"],
      "properties": {
        "mode": {"const": "snapshot"},
        "path": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "model",
        "sandbox",
        "timeout_seconds",
        "repetitions",
        "concurrency",
        "network_access"
      ],
      "properties": {
        "adapter": {"enum": ["fake", "codex-cli"]},
        "model": {"$ref": "#/$defs/nonEmptyString"},
        "sandbox": {"enum": ["read-only", "workspace-write"]},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "repetitions": {"type": "integer", "minimum": 1, "maximum": 20},
        "concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "network_access": {"const": false}
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_agent_runs", "max_judge_runs", "max_wall_seconds"],
      "properties": {
        "max_agent_runs": {"type": "integer", "minimum": 1, "maximum": 256},
        "max_judge_runs": {"type": "integer", "minimum": 1, "maximum": 32},
        "max_wall_seconds": {"type": "integer", "minimum": 1, "maximum": 86400}
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger_threshold", "required_case_pass_rate", "judge_required"],
      "properties": {
        "trigger_threshold": {"$ref": "#/$defs/ratio"},
        "required_case_pass_rate": {"$ref": "#/$defs/ratio"},
        "judge_required": {"type": "boolean"}
      }
    },
    "triggerCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode", "split", "prompt", "inputs", "should_trigger"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "mode": {"const": "trigger"},
        "split": {"enum": ["train", "validation", "holdout"]},
        "prompt": {"$ref": "#/$defs/nonEmptyString"},
        "inputs": {
          "type": "array",
          "maxItems": 64,
          "items": {"$ref": "#/$defs/relativePath"}
        },
        "should_trigger": {"type": "boolean"},
        "repetitions": {"type": "integer", "minimum": 1, "maximum": 20}
      }
    },
    "behaviorCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mode", "split", "prompt", "inputs", "assertions"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "mode": {"const": "behavior"},
        "split": {"enum": ["train", "validation", "holdout"]},
        "prompt": {"$ref": "#/$defs/nonEmptyString"},
        "inputs": {
          "type": "array",
          "maxItems": 64,
          "items": {"$ref": "#/$defs/relativePath"}
        },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {"$ref": "#/$defs/assertion"}
        },
        "trusted_verifier": {"type": "boolean"},
        "repetitions": {"type": "integer", "minimum": 1, "maximum": 20}
      },
      "allOf": [
        {
          "if": {
            "required": ["trusted_verifier"],
            "properties": {"trusted_verifier": {"const": true}}
          },
          "then": {
            "properties": {
              "assertions": {"contains": {"$ref": "#/$defs/verifierCommandAssertion"}}
            }
          }
        },
        {
          "if": {
            "properties": {
              "assertions": {"contains": {"$ref": "#/$defs/verifierCommandAssertion"}}
            }
          },
          "then": {
            "required": ["trusted_verifier"],
            "properties": {"trusted_verifier": {"const": true}}
          }
        }
      ]
    },
    "assertion": {
      "oneOf": [
        {"$ref": "#/$defs/fileExistsAssertion"},
        {"$ref": "#/$defs/fileAbsentAssertion"},
        {"$ref": "#/$defs/pathChangedAssertion"},
        {"$ref": "#/$defs/pathUnchangedAssertion"},
        {"$ref": "#/$defs/textContainsAssertion"},
        {"$ref": "#/$defs/textExcludesAssertion"},
        {"$ref": "#/$defs/regexMatchesAssertion"},
        {"$ref": "#/$defs/jsonValidAssertion"},
        {"$ref": "#/$defs/jsonFieldEqualsAssertion"},
        {"$ref": "#/$defs/diffAllowsOnlyAssertion"},
        {"$ref": "#/$defs/diffExcludesAssertion"},
        {"$ref": "#/$defs/verifierCommandAssertion"}
      ]
    },
    "fileExistsAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "file_exists"},
        "path": {"$ref": "#/$defs/relativePath"}
      }
    },
    "fileAbsentAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "file_absent"},
        "path": {"$ref": "#/$defs/relativePath"}
      }
    },
    "pathChangedAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "path_changed"},
        "path": {"$ref": "#/$defs/relativePath"}
      }
    },
    "pathUnchangedAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "path_unchanged"},
        "path": {"$ref": "#/$defs/relativePath"}
      }
    },
    "textContainsAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path", "value"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "text_contains"},
        "path": {"$ref": "#/$defs/relativePath"},
        "value": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "textExcludesAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path", "value"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "text_excludes"},
        "path": {"$ref": "#/$defs/relativePath"},
        "value": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "regexMatchesAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path", "pattern"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "regex_matches"},
        "path": {"$ref": "#/$defs/relativePath"},
        "pattern": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "jsonValidAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "json_valid"},
        "path": {"$ref": "#/$defs/relativePath"}
      }
    },
    "jsonFieldEqualsAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "path", "value"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "json_field_equals"},
        "path": {"$ref": "#/$defs/relativePath"},
        "value": {
          "type": "object",
          "additionalProperties": false,
          "required": ["field", "equals"],
          "properties": {
            "field": {"$ref": "#/$defs/nonEmptyString"},
            "equals": {}
          }
        }
      }
    },
    "diffAllowsOnlyAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "allow"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "diff_allows_only"},
        "allow": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {"$ref": "#/$defs/relativePath"}
        }
      }
    },
    "diffExcludesAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "deny"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "diff_excludes"},
        "deny": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {"$ref": "#/$defs/relativePath"}
        }
      }
    },
    "verifierCommandAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "argv"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "type": {"const": "verifier_command"},
        "argv": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {"$ref": "#/$defs/nonEmptyString"}
        },
        "cwd": {"$ref": "#/$defs/relativePath"},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600}
      }
    }
  }
}
