{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/skill-evaluation-lab/semantic-review.schema.json",
  "title": "Current Agent Semantic Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluation_id",
    "candidate_tree_sha256",
    "dimensions",
    "assumptions",
    "limitations",
    "observation_decision"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "evaluation_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
    "candidate_tree_sha256": {"$ref": "#/$defs/sha256"},
    "dimensions": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {"$ref": "#/$defs/dimension"}
    },
    "assumptions": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "observation_decision": {"enum": ["not_requested", "requested", "provided"]}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "detail"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "detail": {"type": "string", "minLength": 1}
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "status", "summary", "evidence"],
      "properties": {
        "dimension": {
          "enum": [
            "invocation_boundary",
            "workflow_completeness",
            "information_architecture",
            "tool_contract",
            "safety_and_permissions",
            "verification_and_delivery",
            "scope_and_composability"
          ]
        },
        "status": {"enum": ["pass", "warn", "fail", "not_applicable"]},
        "summary": {"type": "string", "minLength": 1},
        "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
        "recommendation": {"type": "string", "minLength": 1}
      }
    }
  }
}
