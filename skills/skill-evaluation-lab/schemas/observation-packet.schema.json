{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/skill-evaluation-lab/observation-packet.schema.json",
  "title": "Non-executable Observation Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "suite_id",
    "generated_at",
    "execution_mode",
    "sources",
    "cases",
    "packet_fingerprint"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "packet_id": {"$ref": "#/$defs/id"},
    "suite_id": {"$ref": "#/$defs/id"},
    "generated_at": {"type": "string"},
    "execution_mode": {"const": "user_operated_independent_session"},
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "baseline"],
      "properties": {
        "candidate": {"$ref": "#/$defs/source"},
        "baseline": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/source"}
          ]
        }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/case"}
    },
    "packet_fingerprint": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "tree_sha256", "file_count", "total_bytes"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "tree_sha256": {"$ref": "#/$defs/sha256"},
        "file_count": {"type": "integer", "minimum": 0},
        "total_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "size", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "size": {"type": "integer", "minimum": 0},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "kind",
        "variant",
        "prompt",
        "expected_observation",
        "inputs",
        "case_fingerprint"
      ],
      "properties": {
        "case_id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["trigger-positive", "trigger-near-miss", "behavior"]},
        "variant": {"enum": ["candidate", "baseline"]},
        "prompt": {"type": "string", "minLength": 1},
        "expected_observation": {"type": "string", "minLength": 1},
        "inputs": {"type": "array", "items": {"$ref": "#/$defs/input"}},
        "case_fingerprint": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
