{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Evaluation Lab Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "state",
    "status",
    "suite_id",
    "fingerprint",
    "run_id",
    "execution_order",
    "requested_concurrency",
    "effective_concurrency",
    "gates",
    "lab_identity",
    "source_identity",
    "records",
    "budget"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "state": {"enum": ["completed", "failed"]},
    "status": {"enum": ["PASS", "FAIL", "ERROR"]},
    "suite_id": {"$ref": "#/$defs/id"},
    "fingerprint": {"$ref": "#/$defs/sha256"},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,95}$"},
    "execution_order": {"const": "serial-paired-alternating"},
    "requested_concurrency": {"type": "integer", "minimum": 1, "maximum": 4},
    "effective_concurrency": {"const": 1},
    "gates": {"$ref": "#/$defs/gates"},
    "lab_identity": {"$ref": "#/$defs/identity"},
    "source_identity": {"$ref": "#/$defs/sourceIdentity"},
    "records": {
      "type": "array",
      "maxItems": 256,
      "items": {"$ref": "#/$defs/record"}
    },
    "budget": {"$ref": "#/$defs/budget"},
    "error": {"$ref": "#/$defs/error"}
  },
  "allOf": [
    {
      "if": {"properties": {"state": {"const": "failed"}}},
      "then": {
        "required": ["error"],
        "properties": {"status": {"const": "ERROR"}}
      }
    },
    {
      "if": {"properties": {"state": {"const": "completed"}}},
      "then": {
        "not": {"required": ["error"]},
        "properties": {"status": {"enum": ["PASS", "FAIL"]}}
      }
    }
  ],
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:[\\\\/])(?![\\\\/])(?!\\.\\.(?:[\\\\/]|$))(?!.*[\\\\/]\\.\\.(?:[\\\\/]|$)).+$"
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tree_sha256", "file_count"],
      "properties": {
        "tree_sha256": {"$ref": "#/$defs/sha256"},
        "file_count": {"type": "integer", "minimum": 1}
      }
    },
    "sourceIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "baseline"],
      "properties": {
        "candidate": {"$ref": "#/$defs/identity"},
        "baseline": {
          "oneOf": [
            {"const": "none"},
            {"$ref": "#/$defs/identity"}
          ]
        }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger_threshold", "required_case_pass_rate", "judge_required"],
      "properties": {
        "trigger_threshold": {"type": "number", "minimum": 0, "maximum": 1},
        "required_case_pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "judge_required": {"type": "boolean"}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_runs", "judge_runs", "remaining_seconds"],
      "properties": {
        "agent_runs": {"type": "integer", "minimum": 0, "maximum": 256},
        "judge_runs": {"type": "integer", "minimum": 0, "maximum": 32},
        "remaining_seconds": {"type": "number", "minimum": 0, "maximum": 86400}
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "mode",
        "split",
        "repetition",
        "variant",
        "status",
        "workspace",
        "baseline_commit",
        "pairing",
        "expected_trigger",
        "observed_trigger",
        "runner",
        "assertions"
      ],
      "properties": {
        "case_id": {"$ref": "#/$defs/id"},
        "mode": {"enum": ["trigger", "behavior"]},
        "split": {"enum": ["train", "validation", "holdout"]},
        "repetition": {"type": "integer", "minimum": 1, "maximum": 20},
        "variant": {"enum": ["candidate", "baseline"]},
        "status": {"enum": ["PASS", "FAIL"]},
        "workspace": {"$ref": "#/$defs/relativePath"},
        "baseline_commit": {"type": "string", "pattern": "^[0-9a-f]{40}([0-9a-f]{24})?$"},
        "pairing": {"$ref": "#/$defs/pairing"},
        "expected_trigger": {"type": ["boolean", "null"]},
        "observed_trigger": {"type": ["boolean", "null"]},
        "runner": {"$ref": "#/$defs/runner"},
        "assertions": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/assertionSummary"}
          ]
        }
      }
    },
    "pairing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pair_key",
        "prompt_sha256",
        "inputs",
        "model",
        "sandbox",
        "timeout_seconds",
        "network_access",
        "skill_snapshot"
      ],
      "properties": {
        "pair_key": {"type": "string", "minLength": 1},
        "prompt_sha256": {"$ref": "#/$defs/sha256"},
        "inputs": {"type": "array", "maxItems": 64, "items": {"type": "string"}},
        "model": {"type": "string", "minLength": 1},
        "sandbox": {"enum": ["read-only", "workspace-write"]},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 3600},
        "network_access": {"const": false},
        "skill_snapshot": {"enum": ["candidate", "baseline", "none"]}
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "return_code",
        "final",
        "trace_path",
        "stderr_path",
        "duration_seconds",
        "usage",
        "provenance",
        "observation"
      ],
      "properties": {
        "outcome": {"enum": ["passed", "failed"]},
        "return_code": {"type": "integer"},
        "final": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "activation_receipt": {"type": ["string", "null"]},
            "response": {"type": "string"}
          }
        },
        "trace_path": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/relativePath"}]},
        "stderr_path": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/relativePath"}]},
        "duration_seconds": {"type": ["number", "null"], "minimum": 0},
        "usage": {"$ref": "#/$defs/usage"},
        "provenance": {"$ref": "#/$defs/provenance"},
        "observation": {"$ref": "#/$defs/observation"}
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input_tokens": {"type": "integer", "minimum": 0},
        "cached_input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "reasoning_output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "cli_version",
        "model",
        "sandbox",
        "network_access",
        "fingerprint",
        "lab_tree_sha256",
        "prompt_sha256",
        "case_id",
        "attempt",
        "variant"
      ],
      "properties": {
        "adapter": {"enum": ["fake", "codex-cli"]},
        "cli_version": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "sandbox": {"enum": ["read-only", "workspace-write"]},
        "permission_profile": {"type": "string", "minLength": 1},
        "network_access": {"const": false},
        "fingerprint": {"$ref": "#/$defs/sha256"},
        "lab_tree_sha256": {"$ref": "#/$defs/sha256"},
        "prompt_sha256": {"$ref": "#/$defs/sha256"},
        "case_id": {"$ref": "#/$defs/id"},
        "attempt": {"type": "integer", "minimum": 1},
        "variant": {"enum": ["candidate", "baseline"]},
        "skill_tree_sha256": {"$ref": "#/$defs/sha256"},
        "trace": {"type": "object"}
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activation_receipt_exact": {"type": "boolean"}
      }
    },
    "assertionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "counts", "results"],
      "properties": {
        "status": {"enum": ["PASS", "FAIL", "ERROR"]},
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["PASS", "FAIL", "ERROR"],
          "properties": {
            "PASS": {"type": "integer", "minimum": 0},
            "FAIL": {"type": "integer", "minimum": 0},
            "ERROR": {"type": "integer", "minimum": 0}
          }
        },
        "results": {
          "type": "array",
          "maxItems": 64,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["assertion_id", "type", "status", "message", "evidence"],
            "properties": {
              "assertion_id": {"$ref": "#/$defs/id"},
              "type": {"type": "string", "minLength": 1},
              "status": {"enum": ["PASS", "FAIL", "ERROR"]},
              "message": {"type": "string"},
              "evidence": {"type": "object"}
            }
          }
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "outcome"],
      "properties": {
        "code": {"type": "string", "minLength": 1},
        "message": {"type": "string", "minLength": 1},
        "outcome": {"type": "string", "minLength": 1},
        "path": {"type": "string"},
        "guidance": {"type": "string"}
      }
    }
  }
}
