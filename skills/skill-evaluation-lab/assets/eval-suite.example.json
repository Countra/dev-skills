{
  "suite_id": "skill-evaluation-example",
  "skill_path": "..",
  "baseline": {
    "mode": "none"
  },
  "runner": {
    "adapter": "codex-cli",
    "model": "gpt-5.4",
    "sandbox": "workspace-write",
    "timeout_seconds": 180,
    "repetitions": 1,
    "concurrency": 1,
    "network_access": false
  },
  "budgets": {
    "max_agent_runs": 6,
    "max_judge_runs": 2,
    "max_wall_seconds": 1200
  },
  "gates": {
    "trigger_threshold": 0.75,
    "required_case_pass_rate": 1.0,
    "judge_required": false
  },
  "cases": [
    {
      "id": "explicit-skill-evaluation",
      "mode": "trigger",
      "split": "validation",
      "prompt": "为这个 Agent Skill 设计 candidate 与 baseline 的触发和行为评测，并给出可审计指标。",
      "inputs": [],
      "should_trigger": true
    },
    {
      "id": "natural-regression-evaluation",
      "mode": "trigger",
      "split": "validation",
      "prompt": "这次改了工作流说明，帮我验证改前改后的误触发、产物质量和 token 变化。",
      "inputs": [],
      "should_trigger": true
    },
    {
      "id": "ordinary-module-tests",
      "mode": "trigger",
      "split": "validation",
      "prompt": "运行这个 Python 模块现有的单元测试并修复失败。",
      "inputs": [],
      "should_trigger": false
    },
    {
      "id": "general-code-review",
      "mode": "trigger",
      "split": "holdout",
      "prompt": "评审这次提交的代码正确性和潜在回归。",
      "inputs": [],
      "should_trigger": false
    },
    {
      "id": "produce-evaluation-plan",
      "mode": "behavior",
      "split": "validation",
      "prompt": "为一个待升级的 skill 设计离线优先的评测计划，并把结构化结果写入 outputs/evaluation-plan.json。",
      "inputs": [],
      "assertions": [
        {
          "id": "plan-exists",
          "type": "file_exists",
          "path": "outputs/evaluation-plan.json"
        },
        {
          "id": "plan-valid-json",
          "type": "json_valid",
          "path": "outputs/evaluation-plan.json"
        },
        {
          "id": "outputs-only",
          "type": "diff_allows_only",
          "allow": [
            "outputs/**"
          ]
        }
      ]
    }
  ]
}
