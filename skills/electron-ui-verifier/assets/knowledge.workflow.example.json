{
  "schemaVersion": 1,
  "appId": "sample-app",
  "goal": "更新显示名称",
  "aliases": [
    "修改名称",
    "Change display name"
  ],
  "parameterSchema": {
    "display_name": {
      "type": "string",
      "required": true,
      "description": "本轮使用的显示名称",
      "sensitive": true
    }
  },
  "steps": [
    {
      "id": "fill-name",
      "type": "fill",
      "locator": {
        "label": "Display name"
      },
      "value": "${display_name}",
      "postconditions": [
        {
          "type": "value",
          "locator": {
            "label": "Display name"
          },
          "expected": "${display_name}"
        }
      ]
    }
  ]
}
