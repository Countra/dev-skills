{
  "schemaVersion": 1,
  "appId": "sample-app",
  "goal": "采集页面诊断摘要",
  "steps": [
    {
      "id": "page-title",
      "type": "evaluate",
      "value": "documentTitle"
    },
    {
      "id": "console-events",
      "type": "collectConsole",
      "options": {
        "maxEvents": 200
      },
      "continueOnFailure": true
    },
    {
      "id": "page-exceptions",
      "type": "collectExceptions",
      "options": {
        "maxEvents": 100,
        "failOnException": false
      },
      "continueOnFailure": true
    },
    {
      "id": "network-summary",
      "type": "collectNetwork",
      "options": {
        "maxEvents": 300
      },
      "continueOnFailure": true
    }
  ]
}
