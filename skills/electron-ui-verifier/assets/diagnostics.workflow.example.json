{
  "app": {
    "cdp": "http://127.0.0.1:9223"
  },
  "targetType": "page",
  "targetUrlContains": "index.html",
  "readiness": [
    {
      "waitText": "案件",
      "timeoutMs": 30000
    }
  ],
  "steps": [
    {
      "id": "start-marker",
      "evaluate": {
        "allow": true,
        "name": "title",
        "expression": "document.title",
        "saveAs": "page.title"
      }
    },
    {
      "id": "console-after-ready",
      "collectConsole": {
        "levels": [
          "log",
          "warning",
          "error"
        ],
        "maxEvents": 200
      }
    },
    {
      "id": "exceptions-after-ready",
      "collectExceptions": {
        "failOnException": false,
        "maxEvents": 100
      }
    },
    {
      "id": "network-after-ready",
      "collectNetwork": {
        "maxEvents": 300
      }
    },
    {
      "id": "dom-full",
      "domSnapshot": {
        "computedStyles": [
          "display",
          "visibility",
          "position"
        ],
        "maxBytes": 5000000
      },
      "continueOnFailure": true
    },
    {
      "id": "ax-tree",
      "accessibilitySnapshot": {
        "maxNodes": 2000
      },
      "continueOnFailure": true
    }
  ]
}
