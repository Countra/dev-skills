{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.electron-ui-verifier/schemas/operation.schema.json",
  "title": "Durable verifier operation",
  "type": "object",
  "required": [
    "schemaVersion", "operationId", "requestId", "requestFingerprint", "kind", "runId",
    "state", "done", "cancelRequested", "deadlineAt", "createdAt", "updatedAt", "revision"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "operationId": {"type": "string", "format": "uuid"},
    "requestId": {"type": "string", "format": "uuid"},
    "requestFingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "kind": {"enum": ["action", "workflow"]},
    "runId": {"type": "string", "format": "uuid"},
    "state": {"enum": ["queued", "running", "succeeded", "failed", "cancelled", "deadline_exceeded", "unknown"]},
    "done": {"type": "boolean"},
    "cancelRequested": {"type": "boolean"},
    "deadlineAt": {"type": "string", "format": "date-time"},
    "createdAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"},
    "startedAt": {"type": "string", "format": "date-time"},
    "finishedAt": {"type": "string", "format": "date-time"},
    "revision": {"type": "integer", "minimum": 1},
    "response": {"type": "object"},
    "error": {"type": "object"}
  },
  "additionalProperties": false
}
