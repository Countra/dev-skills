{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.electron-ui-verifier/schemas/run.schema.json",
  "title": "Verifier run journal",
  "type": "object",
  "required": ["schemaVersion", "runId", "sessionId", "state", "steps", "artifacts"],
  "properties": {
    "schemaVersion": {"const": 1},
    "runId": {"type": "string", "format": "uuid"},
    "sessionId": {"type": "string", "minLength": 1},
    "appId": {"type": ["string", "null"]},
    "goal": {"type": ["string", "null"]},
    "state": {"enum": ["prepared", "running", "finalizing", "passed", "failed", "aborted"]},
    "createdAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"},
    "steps": {"type": "array", "items": {"type": "object"}, "maxItems": 200},
    "artifacts": {"type": "array", "items": {"$ref": "#/$defs/artifact"}}
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["artifactId", "path", "sha256", "bytes"],
      "properties": {
        "artifactId": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "bytes": {"type": "integer", "minimum": 0},
        "mediaType": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
