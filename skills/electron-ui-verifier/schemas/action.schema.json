{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.electron-ui-verifier/schemas/action.schema.json",
  "title": "Typed verifier action",
  "type": "object",
  "required": ["type"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "type": {
      "enum": [
        "click", "doubleClick", "fill", "select", "check", "uncheck",
        "press", "keyChord", "hover", "scroll", "snapshot", "screenshot",
        "waitText", "waitUrlContains", "evaluate", "extractText",
        "extractTable", "collectConsole", "collectExceptions", "collectNetwork"
      ]
    },
    "locator": {"$ref": "locator.schema.json"},
    "value": {},
    "options": {
      "type": "object",
      "properties": {
        "timeoutMs": {"type": "integer", "minimum": 1, "maximum": 120000},
        "coordinates": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": {"type": "number", "minimum": 0},
            "y": {"type": "number", "minimum": 0}
          },
          "additionalProperties": false
        },
        "label": {"type": "string", "maxLength": 200},
        "allowEvaluate": {"type": "boolean"},
        "maxEvents": {"type": "integer", "minimum": 0, "maximum": 10000},
        "failOnException": {"type": "boolean"},
        "levels": {"type": "array", "items": {"type": "string"}, "maxItems": 20},
        "urlContains": {"type": "string", "maxLength": 2000},
        "includeFailedOnly": {"type": "boolean"},
        "exploratoryOnly": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "postconditions": {
      "type": "array",
      "items": {"$ref": "#/$defs/assertion"},
      "maxItems": 20
    },
    "continueOnFailure": {"type": "boolean"},
    "detour": {"type": "boolean"}
  },
  "$defs": {
    "assertion": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["visible", "hidden", "text", "value", "count", "urlContains", "titleContains", "screenshotQuality"]
        },
        "locator": {"$ref": "locator.schema.json"},
        "expected": {},
        "timeoutMs": {"type": "integer", "minimum": 1, "maximum": 120000}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["click", "doubleClick", "fill", "select", "check", "uncheck", "press", "keyChord"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["postconditions"],
        "properties": {
          "postconditions": {"minItems": 1}
        }
      }
    }
  ],
  "additionalProperties": false
}
