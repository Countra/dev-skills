{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.electron-ui-verifier/schemas/workflow.schema.json",
  "title": "Verifier workflow",
  "type": "object",
  "required": ["goal", "steps"],
  "properties": {
    "schemaVersion": {"const": 1},
    "goal": {"type": "string", "minLength": 1, "maxLength": 500},
    "aliases": {"type": "array", "items": {"type": "string"}, "maxItems": 50},
    "appId": {"type": "string", "minLength": 1},
    "parameterSchema": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/parameter"}
    },
    "steps": {
      "type": "array",
      "items": {"$ref": "action.schema.json"},
      "minItems": 1,
      "maxItems": 200
    },
    "autoFinalize": {"type": "boolean"}
  },
  "$defs": {
    "parameter": {
      "type": "object",
      "properties": {
        "type": {"enum": ["string", "number", "integer", "boolean"]},
        "required": {"type": "boolean"},
        "description": {"type": "string", "maxLength": 500},
        "sensitive": {"type": "boolean", "default": true}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
