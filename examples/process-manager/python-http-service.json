{
  "name": "python-http",
  "kind": "long-running",
  "cwd": "/ABSOLUTE/PATH/TO/WORKSPACE",
  "launcher": {
    "type": "script",
    "interpreter": "/ABSOLUTE/PATH/TO/PYTHON",
    "script": "/ABSOLUTE/PATH/TO/WORKSPACE/python_http.py",
    "args": ["--port", "49401"],
    "pathArgs": []
  },
  "environment": {
    "inherit": ["PATH", "HOME"],
    "set": {},
    "fromEnv": []
  },
  "stop": {
    "graceSeconds": 8
  },
  "readiness": {
    "type": "http",
    "url": "http://127.0.0.1:49401/health",
    "timeoutSeconds": 30
  },
  "logs": {
    "maxBytes": 10485760,
    "backups": 3
  }
}
