{
  "name": "python-worker",
  "kind": "long-running",
  "cwd": "/ABSOLUTE/PATH/TO/WORKSPACE",
  "launcher": {
    "type": "script",
    "interpreter": "/ABSOLUTE/PATH/TO/PYTHON",
    "script": "/ABSOLUTE/PATH/TO/WORKSPACE/python_worker.py",
    "args": [],
    "pathArgs": []
  },
  "environment": {
    "inherit": ["PATH", "HOME"],
    "set": {},
    "fromEnv": ["WORKER_TOKEN"]
  },
  "stop": {
    "graceSeconds": 8
  },
  "readiness": {
    "type": "log",
    "stream": "stdout",
    "pattern": "worker ready",
    "extract": {},
    "scanBytes": 131072,
    "timeoutSeconds": 30
  },
  "logs": {
    "maxBytes": 10485760,
    "backups": 3
  }
}
