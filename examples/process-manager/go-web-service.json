{
  "name": "go-web",
  "kind": "long-running",
  "cwd": "/ABSOLUTE/PATH/TO/GO/PROJECT",
  "launcher": {
    "type": "direct",
    "executable": "/ABSOLUTE/PATH/TO/GO",
    "args": ["run"],
    "pathArgs": ["/ABSOLUTE/PATH/TO/GO/PROJECT/main.go"]
  },
  "environment": {
    "inherit": ["PATH", "HOME"],
    "set": {"PORT": "8099"},
    "fromEnv": []
  },
  "stop": {
    "graceSeconds": 8
  },
  "readiness": {
    "type": "http",
    "url": "http://127.0.0.1:8099/health",
    "timeoutSeconds": 30
  },
  "logs": {
    "maxBytes": 10485760,
    "backups": 3
  }
}
