{
  "name": "python-dynamic",
  "kind": "long-running",
  "cwd": "/ABSOLUTE/PATH/TO/WORKSPACE",
  "launcher": {
    "type": "script",
    "interpreter": "/ABSOLUTE/PATH/TO/PYTHON",
    "script": "/ABSOLUTE/PATH/TO/WORKSPACE/python_dynamic.py",
    "args": [],
    "pathArgs": []
  },
  "environment": {
    "inherit": ["PATH", "HOME"],
    "set": {},
    "fromEnv": []
  },
  "stop": {
    "graceSeconds": 8
  },
  "readiness": {
    "type": "log",
    "stream": "stdout",
    "pattern": "Local: (?P<url>http://127\\.0\\.0\\.1:(?P<port>\\d+))",
    "extract": {
      "urls": ["url"],
      "ports": ["port"]
    },
    "scanBytes": 262144,
    "timeoutSeconds": 30
  },
  "logs": {
    "maxBytes": 10485760,
    "backups": 3
  }
}
