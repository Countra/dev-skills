{
  "task_id": "2026-07-14-feature-electron-ui-verifier-safety-knowledge-closure",
  "plan_revision": 1,
  "lifecycle_route": "managed",
  "plan_profile": "full",
  "goal": {
    "id": "GOAL-01",
    "summary": "把 electron-ui-verifier 升级为安全边界、长操作、批准写入、知识生产复用、安装可移植性和状态保留均有公共端到端证据的 Electron 验证 Skill"
  },
  "requirements": [
    {
      "id": "REQ-01",
      "priority": "must",
      "summary": "以 input-only 瞬时绑定上下文和统一安全投影阻止敏感值进入响应、状态、日志、知识与视觉证据"
    },
    {
      "id": "REQ-02",
      "priority": "must",
      "summary": "删除无后置条件和动作自签风险旁路，以服务端绑定的一次性短期 receipt 授权风险动作"
    },
    {
      "id": "REQ-03",
      "priority": "must",
      "summary": "用 durable operation 提供 mutation 的幂等提交、查询、取消、服务端 deadline、检查点和恢复"
    },
    {
      "id": "REQ-04",
      "priority": "must",
      "summary": "以 immutable objects 和 sealed decision activation 实现 crash-safe 批准，并直接切换新 knowledge layout"
    },
    {
      "id": "REQ-05",
      "priority": "must",
      "summary": "从 production passed steps 生成完整 action assets，并生成只引用有序 action IDs 的 workflow asset"
    },
    {
      "id": "REQ-06",
      "priority": "must",
      "summary": "由服务端加载和校验 asset ID，并闭合 search、compose、reuse 与 reliability stats"
    },
    {
      "id": "REQ-07",
      "priority": "must",
      "summary": "从模块位置派生 skill root，使安装目录与 workspace 状态目录独立且可移植"
    },
    {
      "id": "REQ-08",
      "priority": "must",
      "summary": "提供默认 dry-run、fingerprint-gated、引用保护且逐项报告的 retention/prune"
    },
    {
      "id": "REQ-09",
      "priority": "must",
      "summary": "同步 Skill、文档、schema、assets、CLI、eval 和 CI，并以公共 fixture、Termous 和最终重评证明交付"
    }
  ],
  "acceptance_criteria": [
    {
      "id": "AC-01",
      "requirement_ids": ["REQ-01"],
      "summary": "真实成功和失败链路中的 sentinel binding、credential、URL query/fragment 与 file path 不出现在任何文本输出、持久状态、日志或知识对象"
    },
    {
      "id": "AC-02",
      "requirement_ids": ["REQ-01"],
      "summary": "敏感输入对应区域自动 mask 并通过视觉证据检查，无法稳定 mask 时 fail closed 且不提交 artifact"
    },
    {
      "id": "AC-03",
      "requirement_ids": ["REQ-02"],
      "summary": "缺失 postcondition、自签旁路、非法或重放 receipt 均以零 mutation 拒绝，合法 receipt 只能执行一次"
    },
    {
      "id": "AC-04",
      "requirement_ids": ["REQ-03"],
      "summary": "mutation 快速返回 operationId，相同 requestId 与 digest 幂等，冲突 digest 拒绝，get/cancel 可查询最终状态"
    },
    {
      "id": "AC-05",
      "requirement_ids": ["REQ-03"],
      "summary": "queued、running、deadline、等待超时和重启场景均不自动 replay，取消后后续 mutation 数为零"
    },
    {
      "id": "AC-06",
      "requirement_ids": ["REQ-04"],
      "summary": "批准各写入 phase 故障后，无 decision 对象不可检索，有 decision 时 index 可重建，重复批准返回同一 bundle"
    },
    {
      "id": "AC-07",
      "requirement_ids": ["REQ-04"],
      "summary": "旧 knowledge 仅能通过 exact fingerprint reset 整体退役，不读取、迁移或双写旧资产"
    },
    {
      "id": "AC-08",
      "requirement_ids": ["REQ-05"],
      "summary": "真实 passed workflow 产出完整 action assets 和仅引用有序 action IDs 的 workflow asset"
    },
    {
      "id": "AC-09",
      "requirement_ids": ["REQ-06"],
      "summary": "服务端对 asset 当前 app、version、screen、state、risk、params 与 receipt 重新校验，错误上下文拒绝"
    },
    {
      "id": "AC-10",
      "requirement_ids": ["REQ-06"],
      "summary": "production-approved corpus 可搜索、组合、复用并更新统计，检索质量与性能门槛不退化"
    },
    {
      "id": "AC-11",
      "requirement_ids": ["REQ-07"],
      "summary": "复制 Skill 到临时安装根后可在另一 workspace 完成 init、start、health、stop，状态不写安装根且 owner-empty"
    },
    {
      "id": "AC-12",
      "requirement_ids": ["REQ-08"],
      "summary": "prune preview 不删除，错误 fingerprint 拒绝，apply 只删过期 terminal unprotected 候选并逐项报告"
    },
    {
      "id": "AC-13",
      "requirement_ids": ["REQ-09"],
      "summary": "Skill eval、quick validate、static、公共 fixture 与 CI 定义均与新契约一致且不绕过公共 service/HTTP/CLI"
    },
    {
      "id": "AC-14",
      "requirement_ids": ["REQ-09"],
      "summary": "Termous 隔离只读 smoke、required gates、source-bound 重评和最终审查闭环，默认数据无污染且进程 owner-empty"
    }
  ],
  "nonfunctional_requirements": [
    {
      "id": "NFR-01",
      "summary": "binding、token、URL query/fragment、file path 与用户内容默认不持久化、不回显"
    },
    {
      "id": "NFR-02",
      "summary": "不确定的 compatibility、risk、postcondition、deadline 或 index state 必须 default deny"
    },
    {
      "id": "NFR-03",
      "summary": "requestId、operation、run、receipt 和 decision 在超时、取消、重启与重复请求下可靠且幂等"
    },
    {
      "id": "NFR-04",
      "summary": "object hash、sealed activation、derived index、reset 与 prune 可恢复并可验证"
    },
    {
      "id": "NFR-05",
      "summary": "queue、deadline、operation、history、artifact、output 与 retrieval 资源有界并满足性能门槛"
    },
    {
      "id": "NFR-06",
      "summary": "遵循项目和 Google Python 规范，保持高内聚、单向依赖、薄 CLI 与文件规模预算"
    },
    {
      "id": "NFR-07",
      "summary": "统一 process-manager 接口、锁定 runtime、分离 skill/workspace 并保持三平台公共契约"
    },
    {
      "id": "NFR-08",
      "summary": "稳定 error/state、safe progress、operation/run/asset IDs、hash、generation 与 cleanup 可审计"
    }
  ],
