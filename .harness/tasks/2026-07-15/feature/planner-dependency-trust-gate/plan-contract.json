{
  "task_id": "2026-07-15-feature-planner-dependency-trust-gate",
  "plan_revision": 1,
  "lifecycle_route": "managed",
  "plan_profile": "full",
  "goal": {
    "id": "GOAL-01",
    "summary": "把依赖与技术选型从可用性建议升级为可审计、可执行、可复核的可信度决策门，并由 Planner 与 Executor 共同守住批准结论"
  },
  "requirements": [
    {
      "id": "REQ-01",
      "priority": "must",
      "summary": "Planner 必须先判断依赖是否必要，再按用户或组织策略、现有项目栈、标准库或官方 SDK、生态主流方案、专用例外的顺序完成选型"
    },
    {
      "id": "REQ-02",
      "priority": "must",
      "summary": "依赖候选必须记录稳定版本、采用规模、更新时间、维护活跃度、采用趋势及安全、许可、真实性、兼容性等可信度证据与新鲜度"
    },
    {
      "id": "REQ-03",
      "priority": "must",
      "summary": "任务契约、计划模板、依赖选型附件和 Planner checker 必须以受控字段表达选型模式、候选比较、结论、例外和验证映射"
    },
    {
      "id": "REQ-04",
      "priority": "must",
      "summary": "Planner checker 必须拒绝空门禁、口号式完成声明、缺证据的主流结论及活动任务指针冲突，并提供稳定诊断"
    },
    {
      "id": "REQ-05",
      "priority": "must",
      "summary": "Executor 必须执行批准的依赖身份与版本策略，发现未批准替换、证据过期、弃用或安全状态变化时进入 Research Drift 或 Amendment"
    },
    {
      "id": "REQ-06",
      "priority": "must",
      "summary": "单测、确定性评估、三平台 CI 和仓库文档必须覆盖主流选择、保留现有栈、标准库优先、专用例外、陈旧证据和负向门禁"
    }
  ],
  "acceptance_criteria": [
    {
      "id": "AC-01",
      "requirement_ids": ["REQ-01"],
      "summary": "当任务不新增、更换或升级依赖时可明确选择 none 并保持轻量；触发依赖变更时未完成必要性判断不能通过批准检查"
    },
    {
      "id": "AC-02",
      "requirement_ids": ["REQ-01", "REQ-02"],
      "summary": "选型任务比较现有组件或标准库与二至四个领先候选，并优先遵守用户策略和现有项目栈，不因单项热度强制迁移"
    },
    {
      "id": "AC-03",
      "requirement_ids": ["REQ-02"],
      "summary": "每项正式候选都有稳定性、采用规模、更新时间、维护、趋势、安全、许可、真实性和兼容性结果，以及来源、观察日期、窗口和局限"
    },
    {
      "id": "AC-04",
      "requirement_ids": ["REQ-01", "REQ-02", "REQ-03"],
      "summary": "专用或非主流方案只有在主流基线不能满足明确需求，并记录风险、缓解、回滚与批准要求后才可入选"
    },
    {
      "id": "AC-05",
      "requirement_ids": ["REQ-03", "REQ-04"],
      "summary": "契约与 checker 对缺失字段、无效枚举、过期证据、来源不足、计划契约漂移和仅写 complete 的空门禁给出稳定失败码"
    },
    {
      "id": "AC-06",
      "requirement_ids": ["REQ-05"],
      "summary": "Executor 在实施前和依赖变更阶段核对批准身份、版本策略、manifest 或 lock 范围和证据新鲜度，偏离时停止而非自行替换"
    },
    {
      "id": "AC-07",
      "requirement_ids": ["REQ-04"],
      "summary": "活动任务指针缺失、同任务、终态旧任务和非终态冲突四类情况均有确定行为，非终态冲突默认拒绝覆盖"
    },
    {
      "id": "AC-08",
      "requirement_ids": ["REQ-03", "REQ-04", "REQ-05", "REQ-06"],
      "summary": "Planner 与 Executor 单测、评估和自举 approval checker 全部通过，并由全分支三平台 CI 定义持续验证"
    },
    {
      "id": "AC-09",
      "requirement_ids": ["REQ-06"],
      "summary": "文档以 Go Web 和 ORM 说明主流基线的用法，同时明确 Gin、GORM 等只是有时效证据的示例而非跨项目永久默认"
    }
  ],
  "nonfunctional_requirements": [
    {
      "id": "NFR-01",
      "summary": "不得以 stars、下载量、单一聚合评分或单日快照独立决定选型，所有信号必须按生态、类别和项目适配性解释"
    },
    {
      "id": "NFR-02",
      "summary": "运行时关键依赖证据默认不老于 30 天、普通运行时依赖不老于 60 天、开发测试依赖不老于 90 天，超期必须复核"
    },
    {
      "id": "NFR-03",
      "summary": "已归档、已弃用、来源不真实、许可不允许、版本不兼容或存在未缓解适用高危漏洞的候选必须 fail closed"
    },
    {
      "id": "NFR-04",
      "summary": "趋势缺少可靠历史数据时必须标记 insufficient-data、披露限制并交叉验证，不得伪造增长结论"
    },
    {
      "id": "NFR-05",
      "summary": "direct 和无依赖变更任务保持渐进披露；只有 add、replace、upgrade 或关键 retain 决策触发完整证据成本"
    },
    {
      "id": "NFR-06",
      "summary": "实现保持 Python 3.11+ 标准库、模块高内聚、稳定诊断、跨 Windows、Linux、macOS 且不新增后台服务"
    },
    {
      "id": "NFR-07",
      "summary": "计划、契约、附件、Executor handoff、测试和文档使用同一受控术语与 ID，检查器只验证可证明事实"
    }
  ],
